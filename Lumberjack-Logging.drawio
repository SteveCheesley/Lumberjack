        <mxCell id="TvdYabubaMgP4hZpLByh-2" value="I&#39;m not convinced I need this yet.. I might be able to solve the issue by making FileOutputWriter and StandardOutputWriter thread safe&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;I&#39;ll implement this last.&lt;/div&gt;" style="shape=note2;boundedLbl=1;whiteSpace=wrap;html=1;size=25;verticalAlign=top;align=center;" parent="1" vertex="1">
          <mxGeometry x="620" y="80" width="310" height="150" as="geometry" />
        </mxCell>
        <mxCell id="TvdYabubaMgP4hZpLByh-5" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;b&gt;LogSources&lt;/b&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot; style=&quot;border-style:solid;&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;&quot;&gt;- default_: LogSource&lt;/p&gt;&lt;p style=&quot;margin:0px;margin-left:4px;&quot;&gt;- sources_ : map&amp;lt;std::string, LogSource&amp;gt;&lt;/p&gt;&lt;p style=&quot;margin:0px;margin-left:4px;&quot;&gt;- &lt;u&gt;pInstance_&lt;/u&gt; : LogSources*&lt;/p&gt;&lt;p style=&quot;margin:0px;margin-left:4px;&quot;&gt;- &lt;u&gt;mutex_&lt;/u&gt; : std::mutex&lt;/p&gt;&lt;hr size=&quot;1&quot; style=&quot;border-style:solid;&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;- LogSources(loggerConfiguration: LoggerConfiguration)&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;margin: 0px 0px 0px 4px;&quot;&gt;+&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;u&gt;getInstance&lt;/u&gt;() : LogSources&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;margin: 0px 0px 0px 4px;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;+ log(caller: T*, level: LogLevel, message: std::string)&lt;/span&gt;&lt;/p&gt;" style="verticalAlign=top;align=left;overflow=fill;html=1;whiteSpace=wrap;" parent="1" vertex="1">
          <mxGeometry x="-144" y="620" width="397" height="160" as="geometry" />
        </mxCell>
        <mxCell id="skFjbr4E7Fnc3YblYDC3-4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0;entryY=0.5;entryDx=0;entryDy=0;endArrow=none;endFill=0;" parent="1" source="TvdYabubaMgP4hZpLByh-6" target="Gi5KEacH5U4bPrpyxMOf-2" edge="1">
