        <mxCell id="wcohfw5u-uyFV9caVVyn-1" value="Decision: Switching this to a class so that I can enforce immutability" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;" parent="1" vertex="1">
